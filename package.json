{
  "name": "vibe-game",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 4317",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "tsx server/index.ts",
    "check": "tsc --noEmit",
    "test": "tsx tests/server-smoke.ts"
  },
  "dependencies": {
    "@colyseus/schema": "4.0.27",
    "@colyseus/sdk": "0.17.43",
    "@colyseus/ws-transport": "0.17.13",
    "colyseus": "0.17.10",
    "express": "5.2.1",
    "phaser": "4.2.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "concurrently": "10.0.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "8.1.5"
  }
}
